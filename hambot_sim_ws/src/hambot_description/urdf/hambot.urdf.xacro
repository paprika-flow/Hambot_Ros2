<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="hambot">

  <!-- ========================================== -->
  <!-- 0. CONFIGURABLE SPECIFIC PROPERTIES        -->
  <!-- ========================================== -->
  <!-- Chassis Dimensions -->
  <xacro:property name="chassis_len"   value="0.193"/>  <!-- 193 mm -->
  <xacro:property name="chassis_width" value="0.157"/>  <!-- 157 mm -->
  <xacro:property name="chassis_hgt"   value="0.100"/>  <!-- 100 mm -->
  <xacro:property name="chassis_mass"  value="2.5"/>

  <!-- Wheel Dimensions & Placement -->
  <xacro:property name="wheel_rad"     value="0.045"/>  <!-- 45 mm radius -->
  <xacro:property name="wheel_len"     value="0.010"/>  <!-- 10 mm thickness -->
  <xacro:property name="wheel_mass"    value="0.15"/>
  <xacro:property name="wheel_joint_y" value="0.0995"/> <!-- 16mm clearance from chassis side -->
  <xacro:property name="wheel_joint_x" value="0.051"/>  <!-- 12mm clearance between wheels -->

  <!-- Ground Clearance & Coordinate Math -->
  <xacro:property name="base_link_z_offset" value="0.071"/> <!-- Ground clearance 21mm + half chassis height -->
  <xacro:property name="wheel_joint_z"      value="${wheel_rad - base_link_z_offset}"/> <!-- -26 mm relative to base_link -->

  <!-- Camera Stand (Support) -->
  <xacro:property name="stand_len"     value="0.010"/>  <!-- 10 mm -->
  <xacro:property name="stand_width"   value="0.092"/>  <!-- 92 mm -->
  <xacro:property name="stand_hgt"     value="0.250"/>  <!-- 250 mm -->
  <xacro:property name="stand_joint_x" value="-0.0915"/> <!-- Positioned at the rear end of chassis -->

  <!-- Camera -->
  <xacro:property name="camera_len"     value="0.015"/> <!-- 15 mm -->
  <xacro:property name="camera_width"   value="0.090"/> <!-- 90 mm -->
  <xacro:property name="camera_hgt"     value="0.025"/> <!-- 25 mm -->
  <xacro:property name="camera_joint_z" value="0.220"/> <!-- 220 mm above top of chassis -->
  <xacro:property name="camera_joint_x" value="0.0125"/> <!-- Flush on front face of the stand -->

  <!-- ========================================== -->
  <!-- 1. MATERIALS & INERTIAL MACROS             -->
  <!-- ========================================== -->
  <material name="blue"><color rgba="0.1 0.1 0.8 1.0"/></material>
  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0" 
               iyy="${(m/12) * (w*w + d*d)}" iyz="0.0" 
               izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0.0" ixz="0.0" 
               iyy="${(m/12) * (3*r*r + h*h)}" iyz="0.0" 
               izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <!-- ========================================== -->
  <!-- 2. ROBOT BASE CHASSIS                      -->
  <!-- ========================================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_link_z_offset}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="${chassis_len} ${chassis_width} ${chassis_hgt}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="${chassis_len} ${chassis_width} ${chassis_hgt}"/></geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}" w="${chassis_len}" h="${chassis_width}" d="${chassis_hgt}"/>
  </link>

  <!-- ========================================== -->
  <!-- 3. WHEELS (4-Wheel Diff Drive)             -->
  <!-- ========================================== -->
  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${x_reflect*wheel_joint_x} ${y_reflect*wheel_joint_y} ${wheel_joint_z}" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

    <link name="${prefix}_wheel">
      <visual>
        <geometry><cylinder radius="${wheel_rad}" length="${wheel_len}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_rad}" length="${wheel_len}"/></geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_rad}" h="${wheel_len}"/>
    </link>
  </xacro:macro>

  <xacro:wheel prefix="front_left"  x_reflect="1"  y_reflect="1" />
  <xacro:wheel prefix="front_right" x_reflect="1"  y_reflect="-1" />
  <xacro:wheel prefix="rear_left"   x_reflect="-1" y_reflect="1" />
  <xacro:wheel prefix="rear_right"  x_reflect="-1" y_reflect="-1" />

  <!-- ========================================== -->
  <!-- 4. SIMULATED SENSORS                       -->
  <!-- ========================================== -->

  <!-- LiDAR Frame & Gazebo Sensor (Located in the Center on Top of Chassis) -->
  <link name="laser_frame">
    <visual>
      <!-- Shifted visual cylinder origin up by half its height so it sits on top of chassis -->
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.04"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.04"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.1" r="0.03" h="0.04"/>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 ${chassis_hgt/2}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="laser_frame">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- Camera Stand (Support Mast) -->
  <link name="camera_stand">
    <visual>
      <!-- Visual geometry origin shifted up so the bottom of the stand aligns with the joint link origin -->
      <origin xyz="0 0 ${stand_hgt/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${stand_len} ${stand_width} ${stand_hgt}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${stand_hgt/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${stand_len} ${stand_width} ${stand_hgt}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.15" w="${stand_len}" h="${stand_width}" d="${stand_hgt}"/>
  </link>

  <joint name="stand_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_stand"/>
    <origin xyz="${stand_joint_x} 0 ${chassis_hgt/2}" rpy="0 0 0"/>
  </joint>

  <!-- Camera Frame & Gazebo Sensor -->
  <link name="camera_frame">
    <visual>
      <geometry>
        <box size="${camera_len} ${camera_width} ${camera_hgt}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="${camera_len} ${camera_width} ${camera_hgt}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.05" w="${camera_len}" h="${camera_width}" d="${camera_hgt}"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="camera_stand"/>
    <child link="camera_frame"/>
    <origin xyz="${camera_joint_x} 0 ${camera_joint_z}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="camera_frame">
    <sensor name="camera" type="rgbd_camera">
      <pose>0 0 0 0 0 0</pose>
      <topic>camera</topic>
      <update_rate>5</update_rate>
      <camera>
        <horizontal_fov>1.274</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
    </sensor>
  </gazebo>

  <!-- ========================================== -->
  <!-- 5. GAZEBO DIFF DRIVE SYSTEMS PLUGIN        -->
  <!-- ========================================== -->
  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <!-- Automatically calculated from variables to maintain accurate physical values -->
      <wheel_separation>${wheel_joint_y * 2}</wheel_separation>
      <wheel_radius>${wheel_rad}</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>

    <plugin filename="ignition-gazebo-joint-state-publisher-system" name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

</robot>